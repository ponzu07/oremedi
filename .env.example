# OreMedi Environment Configuration
#
# Setup:
#   1. Copy this file to .env: cp .env.example .env
#   2. Generate your password hash: node -e "require('bcrypt').hash('YOUR_PASSWORD', 10).then(h => console.log(h))"
#   3. Generate a JWT secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   4. Adjust paths to match your NAS volume mounts

# Authentication
# Default password: "oremedi" (change this in production!)
PASSWORD_HASH=$2b$10$WVq75QLG7A6DzBbtQ69WW.nPhnKCx1CXqc4DIR61CyF6NufuJgqU.
JWT_SECRET=change_me_to_a_random_string

# Database
DATABASE_PATH=data/oremedi.db

# Media paths (adjust for your NAS)
# Local dev: use local directories
# Docker: these are container paths, mapped via docker-compose volumes
MEDIA_PATH=/media
CONVERTED_PATH=/media-converted
